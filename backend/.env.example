# PostgreSQL (Supabase / Neon / local)
DATABASE_URL=jdbc:postgresql://localhost:5432/copa2026

# JWT — use uma string longa e aleatória (mínimo 32 chars)
JWT_SECRET=copa2026_super_secret_key_must_be_at_least_256_bits_long

# URL do frontend para CORS (sem barra final)
FRONTEND_URL=http://localhost:3000
